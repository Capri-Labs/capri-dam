# .env.example
# Copy to .env and fill in real values. Do NOT commit your .env file.

# Rails master key (decrypts config/credentials.yml.enc).
# Alternatively place it in config/master.key.
# RAILS_MASTER_KEY=

# Redis (Sidekiq queues, caching, Action Cable)
# REDIS_URL=redis://localhost:6379/0

# Keycloak SSO (OmniAuth)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_SECRET=dev_secret_123

#!/usr/bin/env bash
# bin/check-commit-msg
#
# Called by the git commit-msg hook (installed at .git/hooks/commit-msg).
# Receives the path to the commit message file as $1.
#
# Rules enforced on the subject line (first line):
#   1. Must not be empty.
#   2. Must start with a capital letter (A–Z).
#   3. Must be <= 72 characters.
#   4. Must NOT end with a period.
#   5. Should be in the imperative/declarative mood (advisory only).
# A blank line must separate the subject from the body (if a body exists).
#
# Exit 0 = OK   Exit 1 = reject commit
#
# Bypass (not recommended):  COMMIT_MSG_WARN_ONLY=1 git commit ...
# Auto-skipped for merge, revert, fixup!, squash! and amend-template commits.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

warn_only="${COMMIT_MSG_WARN_ONLY:-0}"
MSG_FILE="$1"
MAX_SUBJECT_LEN=72

# Strip comment lines (git includes them) and capture the first non-empty line.
SUBJECT="$(grep -vE '^\s*#' "$MSG_FILE" | sed '/^\s*$/d' | head -n 1 || true)"

# Allow automated / special commit types through untouched.
if echo "$SUBJECT" | grep -qE '^(Merge|Revert|fixup!|squash!|Reapply) '; then
  exit 0
fi

PROBLEMS=()

# 1. Not empty
if [[ -z "$SUBJECT" ]]; then
  echo -e "${RED}✗ Commit message is empty.${NC}"
  [[ "$warn_only" -eq 1 ]] && exit 0 || exit 1
fi

# 2. Starts with a capital letter
if ! echo "$SUBJECT" | grep -qE '^[A-Z]'; then
  PROBLEMS+=("Subject must start with a capital letter.")
fi

# 3. Length limit
if [[ "${#SUBJECT}" -gt "$MAX_SUBJECT_LEN" ]]; then
  PROBLEMS+=("Subject is ${#SUBJECT} chars; keep it <= ${MAX_SUBJECT_LEN}.")
fi

# 4. No trailing period
if echo "$SUBJECT" | grep -qE '\.$'; then
  PROBLEMS+=("Subject must not end with a period.")
fi

# 5. Second line (if any) must be blank
SECOND_LINE="$(grep -vE '^\s*#' "$MSG_FILE" | sed -n '2p' || true)"
if [[ -n "$SECOND_LINE" ]]; then
  PROBLEMS+=("Separate subject from body with a blank line.")
fi

if [[ "${#PROBLEMS[@]}" -gt 0 ]]; then
  echo -e "${YELLOW}⚠  Commit message problems:${NC}"
  echo -e "   Subject: ${SUBJECT}"
  for p in "${PROBLEMS[@]}"; do
    echo "     • $p"
  done
  echo ""
  echo "   Example of a good message:"
  echo "     Add metadata export cleanup worker"
  echo ""
  if [[ "$warn_only" -eq 1 ]]; then
    echo -e "${YELLOW}COMMIT_MSG_WARN_ONLY=1 — commit allowed despite problems.${NC}"
    exit 0
  fi
  echo "   To bypass (not recommended): COMMIT_MSG_WARN_ONLY=1 git commit ..."
  exit 1
fi

echo -e "${GREEN}✓ Commit message looks good.${NC}"
exit 0


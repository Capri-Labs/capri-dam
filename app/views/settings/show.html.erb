<div id="root"
     data-view="settings"
     data-user-is-admin="<%= current_user.admin? %>"
     data-user-email="<%= current_user.email %>"
     data-settings-site-name="<%= Setting.get('site_name') %>"
     data-settings-notifications="<%= Setting.get('notifications_enabled') %>"
     data-settings-mimes="<%= Setting.get('allowed_mimes') %>"

     <%# --- DYNAMIC SYSTEM VIEW ATTRIBUTES --- %>
     data-current-sub-view="<%= @sub_view %>"
     <%# NOTE: intentionally NOT wrapped in `raw` — letting ERB HTML-escape
         the JSON string prevents stored XSS if any nested value (e.g. an
         admin-entered SMTP host/username) contains a `'`, `<`, or `&`. The
         browser decodes HTML entities in `dataset` values automatically, so
         `JSON.parse(el.dataset.smtpConfig)` on the frontend is unaffected. %>
     data-smtp-config='<%= (@smtp_config || {}).to_json %>'

     <%# --- NEW STORAGE ATTRIBUTES --- %>
     data-active-provider="<%= @active_provider %>"
     data-all-configs='<%= @all_configs.to_json %>'

     <%# Guarding map with a safe conditional in case system_apps is nil %>
     data-system-apps='<%= (@system_apps || []).map { |app|
          {
            id: app.id,
            name: app.name,
            uid: app.uid
          }
     }.to_json %>'>
</div>
<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= content_for(:title) || "Headless DAM" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <link rel="icon" href="/icon.png" type="image/png">

  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
</head>

<%#
    BODY: Prevents global scrolling. We want the inner content to scroll,
    leaving the Header and Sidebar perfectly fixed.
  %>
<body style="margin: 0; padding: 0; display: flex; flex-direction: column; height: 100vh; overflow: hidden; background-color: #f4f7fb;">

<%# 1. Global Header (Fixed at Top) %>
<header id="global-header" style="flex-shrink: 0; width: 100%; z-index: 20; background: #fff; border-bottom: 1px solid #e2e8f0;">
  <%= render "layouts/header" %>
</header>

<%# 2. Lower Split: Sidebar + Scrollable Content %>
<div style="display: flex; flex-grow: 1; overflow: hidden;">

  <%# 3. Global Sidebar Container (Fixed on Left) %>
  <%# React will mount the Sidebar component here %>
  <% if user_signed_in? %>
    <div
      id="react-sidebar-root"
      data-active-view="<%= @active_view || 'Dashboard' %>"
      style="flex-shrink: 0; height: 100%; overflow-y: auto; background: #fff; border-right: 1px solid #e2e8f0; z-index: 10;"
    >
    </div>
  <% end %>

  <%# 4. Scrollable Content Area (Right Side) %>
  <div id="scrollable-content" style="flex-grow: 1; display: flex; flex-direction: column; overflow-y: auto; position: relative">

    <%# Flash Messages %>
    <% if notice || alert %>
      <section id="flash-container" style="flex-shrink: 0;">
        <% if notice %>
          <div style="background: #e6f4ea; color: #137333; padding: 1rem; text-align: center; border-bottom: 1px solid #ceead6;">
            <%= notice %>
          </div>
        <% end %>
        <% if alert %>
          <div style="background: #fce8e6; color: #c5221f; padding: 1rem; text-align: center; border-bottom: 1px solid #fad2cf;">
            <%= alert %>
          </div>
        <% end %>
      </section>
    <% end %>

    <%# 5. Main View Area %>
    <%# React page components (AssetExplorer, DuplicateManager) mount inside the yield %>
    <main id="view-wrapper" style="flex-grow: 1; display: flex; flex-direction: column; min-height: 870px">
      <%= yield %>
    </main>

    <%# 6. Global Footer Container %>
    <%# Pushed below the main content. React will mount the Footer component here %>
    <% if user_signed_in? %>
      <footer id="react-footer-root" style="flex-shrink: 0;"></footer>
    <% end %>
  </div>
</div>
</body>
</html>
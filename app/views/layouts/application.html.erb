<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Headless DAM" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>

  <%# Use flexbox to push the footer to the bottom %>
  <body style="margin: 0; display: flex; flex-direction: column; min-height: 100vh; background-color: #f8fafc;">

  <%# 1. Global Header %>
  <%= render "layouts/header" %>

  <%# 2. Main Content Area %>
  <main style="flex: 1;">
    <% if notice %>
      <div style="background: #c6f6d5; color: #22543d; padding: 0.75rem; text-align: center; font-size: 0.9rem;"><%= notice %></div>
    <% end %>

    <%= yield %>
  </main>

  <%# 3. Global Footer %>
  <%= render "layouts/footer" %>

  </body>
</html>
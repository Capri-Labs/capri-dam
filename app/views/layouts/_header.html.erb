<%# app/views/layouts/_header.html.erb %>
<div id="header-root"
     data-user-name="<%= current_user&.display_name %>"
     data-signed-in="<%= user_signed_in? %>"
     data-is-admin="<%= current_user&.admin? %>"
     data-is-super-admin="<%= current_user&.super_admin? %>"
     data-impersonating="<%= impersonating? %>"
     data-impersonated-user='<%= impersonating? ? { id: current_user.id, display_name: current_user.display_name, email: current_user.email }.to_json : "null" %>'
     data-true-user-name="<%= true_user&.display_name %>">
</div>

<%# Keep the spacer so content doesn't hide under the fixed header %>
<div style="height: 64px;"></div>
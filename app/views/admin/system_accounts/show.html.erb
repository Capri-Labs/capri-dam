<div style="max-width: 800px; margin: 2rem auto; font-family: sans-serif; border: 1px solid #e2e8f0; padding: 2rem; border-radius: 8px; background: #fff;">
  <h1 style="color: #2d3748;">🔑 Application Credentials</h1>

  <p style="background: #fff5f5; color: #c53030; padding: 1rem; border-left: 4px solid #c53030; margin-bottom: 2rem;">
    <strong>Warning:</strong> For security reasons, Please copy and store it in a secure vault.
  </p>

  <div style="margin-top: 2rem;">
    <label style="font-weight: bold; color: #4a5568;">Application Name</label>
    <div style="padding: 0.5rem; background: #f7fafc; margin-bottom: 1rem; border-radius: 4px;"><%= @app.name %></div>

    <label style="font-weight: bold; color: #4a5568;">Client ID (UID)</label>
    <div style="display: flex; gap: 10px; margin-bottom: 1rem;">
      <input type="text" value="<%= @app.uid %>" readonly style="flex-grow: 1; padding: 0.5rem; background: #edf2f7; border: 1px solid #cbd5e0; border-radius: 4px;">
    </div>

    <label style="font-weight: bold; color: #4a5568;">Client Secret</label>
    <div style="display: flex; gap: 10px; margin-bottom: 2rem;">
      <input type="text" value="<%= @app.secret %>" readonly style="flex-grow: 1; padding: 0.5rem; background: #fefcbf; border: 1px solid #ecc94b; font-family: monospace; border-radius: 4px;">
    </div>

    <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #e2e8f0; padding-top: 2rem;">
      <%= link_to "Back", settings_path, style: "display: inline-block; background: #48bb78; color: white; padding: 0.8rem 1.5rem; text-decoration: none; border-radius: 4px; font-weight: bold;" %>

      <%# --- The Revoke Button --- %>
      <%= button_to "Revoke", admin_system_account_path(@app),
                    method: :delete,
                    data: { turbo_confirm: "Are you sure? This will immediately disable this Client ID and Secret. This action cannot be undone." },
                    style: "background: none; border: 1px solid #e53e3e; color: #e53e3e; padding: 0.8rem 1.5rem; border-radius: 4px; cursor: pointer; font-weight: bold;" %>
    </div>
  </div>
</div>